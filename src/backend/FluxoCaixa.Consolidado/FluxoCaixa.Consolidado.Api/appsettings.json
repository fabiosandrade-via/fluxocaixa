{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {
    "ConnectionString": "${MONGO_CONSOLIDADO_CONNECTION_STRING}",
    "DatabaseName": "${MONGO_CONSOLIDADO_DB}",
    "ColecaoSaldos": "saldos_consolidados"
  },
  "ConnectionStrings": {
    "Redis": "${REDIS_CONNECTION_STRING}"
  },
  "Kafka": {
    "BootstrapServers": "${KAFKA_BOOTSTRAP_SERVERS}",
    "GroupId": "consolidado-consumer-group",
    "TopicLancamentos": "lancamentos-events"
  },
  "Cors": {
    "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}"
  }
}
