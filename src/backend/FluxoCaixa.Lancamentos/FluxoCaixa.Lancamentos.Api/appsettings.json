{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "LancamentosDb": "Host=${DB_LANCAMENTOS_HOST};Port=${DB_LANCAMENTOS_PORT};Database=${DB_LANCAMENTOS_NAME};Username=${DB_LANCAMENTOS_USER};Password=${DB_LANCAMENTOS_PASSWORD}"
  },
  "Kafka": {
    "BootstrapServers": "${KAFKA_BOOTSTRAP_SERVERS}",
    "TopicLancamentos": "lancamentos-events"
  },
  "Cors": {
    "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}"
  }
}
